# Jellyfin AI Recommender - Backend Environment Variables Example
# Copy this file to .env and fill in your values

# Database Configuration (Required for Prisma)
DATABASE_URL="file:./dev.db"
# Optional persistent cache DB path (SQLite). If unset, defaults near DATABASE_URL as cache.db
# CACHE_DB_PATH="./cache.db"

# Server Configuration
PORT=3001

# API Keys and URLs (Optional - can be configured via UI Settings page)
# These will be stored in the database SystemConfig table after first setup
# Leave empty to use the Setup Wizard in the browser

# JELLYFIN_URL=http://your-jellyfin-server:8096
# JELLYSEERR_URL=http://your-jellyseerr:5055
# JELLYSEERR_API_KEY=your-jellyseerr-api-key
# TMDB_API_KEY=your-tmdb-api-read-access-token-or-key
# GEMINI_API_KEY=your-google-gemini-api-key
# AI_PROVIDER="google" # Options: "google" or "openrouter"
# OPENROUTER_API_KEY=your-openrouter-key
# AI_MODEL="gemini-3-flash-preview"

# Note: The application will use values from the database (SystemConfig table)
# if they exist. Environment variables serve as fallback defaults.

# Security Configuration
# SSRF Protection: Allowlist additional domains for image downloads and API requests
# Add your custom Jellyseerr/Jellyfin domains if hosted on non-standard domains
# Format: Comma-separated list of domains (no http://, no paths)
# Example: ALLOWED_IMAGE_DOMAINS=myjellyfin.example.com,cdn.myserver.net
# ALLOWED_IMAGE_DOMAINS=

# Scheduler Configuration
# Timezone for the weekly watchlist cron job (Mondays at 03:00).
# Accepts any IANA timezone string. Falls back to TZ env var, then UTC.
# SCHEDULER_TIMEZONE=Europe/Helsinki

# Image Storage Configuration
# IMAGE_DIR=/app/images  # Directory for local image cache (Docker: /app/images)

# Session Management
# SESSION_SECRET: Optional. Auto-generated on first run and stored in /app/data/.session_secret
#   (persists across Docker restarts via volume). Set explicitly for multi-instance deployments.
# SESSION_SECRET=your-random-64-char-hex-secret-here

# SESSION_TTL_DAYS: Session validity in days (sliding window). Default: 30
# SESSION_TTL_DAYS=30
